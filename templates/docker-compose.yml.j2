services:
  app:
    image: "{{ docker_image }}:{{ docker_tag }}"
    container_name: project-devops-deploy
    restart: unless-stopped
    ports:
      - "80:8080"
      - "9090:9090"
    environment:
      JAVA_OPTS: "-Dspring.profiles.active=prod"
      SPRING_PROFILES_ACTIVE: prod
      SPRING_DATASOURCE_URL: "{{ spring_datasource_url }}"
      SPRING_DATASOURCE_USERNAME: "{{ spring_datasource_username }}"
      SPRING_DATASOURCE_PASSWORD: "{{ spring_datasource_password }}"
      STORAGE_S3_BUCKET: "{{ storage_s3_bucket | default('') }}"
      STORAGE_S3_REGION: "{{ storage_s3_region | default('') }}"
      STORAGE_S3_ENDPOINT: "{{ storage_s3_endpoint | default('') }}"
      STORAGE_S3_ACCESSKEY: "{{ storage_s3_accesskey | default('') }}"
      STORAGE_S3_SECRETKEY: "{{ storage_s3_secretkey | default('') }}"
      STORAGE_S3_CDNURL: "{{ storage_s3_cdnurl | default('') }}"
      MANAGEMENT_SERVER_PORT: "9090"
